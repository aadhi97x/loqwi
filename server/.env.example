GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
PORT=3000

# Optional — enables real rate limiting that works across serverless
# instances (e.g. on Vercel). Get these free at https://console.upstash.com
# (Redis database -> REST API section). If unset, falls back to an
# in-memory counter (fine for a single long-running process, not for
# stateless serverless functions).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
